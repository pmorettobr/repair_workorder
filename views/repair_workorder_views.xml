<odoo>
    <record id="repair_workorder_form" model="ir.ui.view">
        <field name="name">repair.workorder.form</field>
        <field name="model">repair.workorder</field>
        <field name="arch" type="xml">
            <form string="Repair Workorder">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="repair_id"/>
                        <field name="workcenter_id"/>
                        <field name="current_employee_id"/>
                        <field name="state"/>
                        <field name="display_time"/>
                    </group>
                    <notebook>
                        <page string="Time Logs">
                            <field name="time_ids">
                                <tree editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="duration"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
